# Browser entry and direct API ports exposed on the host.
WEB_PORT=5173
API_PORT=8787

# Change this when the browser uses another scheme, host, or port.
CORS_ORIGIN=http://192.168.51.252:5173

# 数据库配置（默认启用 SQLite）。
# SQLite 数据会持久化到 docker-compose.yaml 定义的命名卷中。
DATABASE_URL=file:./data/mcp-debug.db
DB_DIALECT=sqlite

# PostgreSQL 配置示例：
# 1. 注释掉上面的两行 SQLite 配置。
# 2. 取消下面对应场景两行配置前的注释。
# 3. 将用户名、密码、主机、端口和数据库名替换为实际值。
# 注意：当前 docker-compose.yaml 不会创建 PostgreSQL，数据库必须已存在，
# 并且必须允许 api 容器通过网络访问。
#
# PostgreSQL 运行在 Docker 宿主机上（Docker Desktop）：
# DATABASE_URL=postgresql://username:password@host.docker.internal:5432/mcp_debug
# DB_DIALECT=postgres
#
# PostgreSQL 运行在其他服务器上，填写服务器 IP 地址或域名：
# DATABASE_URL=postgresql://username:password@192.168.1.100:5432/mcp_debug
# DB_DIALECT=postgres
#
# 用户名或密码包含特殊字符时，需要进行 URL 百分号编码。
# 例如密码 "p@ss#word" 应在 DATABASE_URL 中写成 "p%40ss%23word"。
